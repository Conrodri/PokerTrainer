{
  "name": "poker-trainer-backend",
  "version": "1.0.0",
  "description": "Poker Trainer API",
  "main": "dist/server.js",
  "scripts": {
    "dev:schema": "node scripts/gen-dev-schema.js",
    "dev": "npm run dev:schema && prisma generate --schema=prisma/dev.prisma && ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:push:dev": "npm run dev:schema && prisma db push --schema=prisma/dev.prisma",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio --schema=prisma/dev.prisma",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "prisma": "^5.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
